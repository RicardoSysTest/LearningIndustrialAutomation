PROGRAM main
  VAR
    TON0 : TON;
    Timer : TIME := T#5s;
    Time_Counter : TIME;
    Start : BOOL;
    Output : BOOL;
  END_VAR

  TON0(IN := Start, PT := Timer);
  Output := TON0.Q;
  Time_Counter := TON0.ET;
END_PROGRAM


CONFIGURATION Config0

  RESOURCE Res0 ON PLC
    TASK task0(INTERVAL := T#20ms,PRIORITY := 1);
    PROGRAM instance0 WITH task0 : main;
  END_RESOURCE
END_CONFIGURATION

